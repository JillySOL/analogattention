---
import Layout from '@/layouts/Layout.astro'
import { getCollection, render } from 'astro:content'
import { Badge } from '@/components/ui/badge'
import { Button } from '@/components/ui/button'
import { Separator } from '@/components/ui/separator'
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator
} from '@/components/ui/breadcrumb'
import { ArrowUpRightIcon, ChevronLeftIcon } from 'lucide-react'

export async function getStaticPaths() {
  const entries = await getCollection('directory')
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry }
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)

// Related items: same category, excluding this one
const allItems = await getCollection('directory')
const relatedItems = allItems
  .filter(item => item.data.category === entry.data.category && item.id !== entry.id)
  .slice(0, 3)

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  keywords: entry.data.tags.join(', ')
}
---

<Layout title={`${entry.data.title} — Directory`} description={entry.data.description} schema={schema}>
  <section class='py-8 sm:pt-16 sm:pb-24'>
    <div class='mx-auto max-w-3xl space-y-10 px-4 sm:px-6 lg:px-8'>
      {/* Breadcrumb */}
      <Breadcrumb>
        <BreadcrumbList>
          <BreadcrumbItem>
            <BreadcrumbLink href='/'>Home</BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <BreadcrumbLink href='/directory'>Directory</BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <BreadcrumbPage>{entry.data.title}</BreadcrumbPage>
          </BreadcrumbItem>
        </BreadcrumbList>
      </Breadcrumb>

      {/* Header */}
      <div class='space-y-4'>
        <div class='flex flex-wrap items-center gap-2'>
          <span class='text-[0.68rem] font-semibold uppercase tracking-widest text-muted-foreground'>
            {entry.data.category}
          </span>
          {entry.data.featured && (
            <span class='rounded-full bg-muted px-2 py-0.5 text-[0.65rem] font-medium text-muted-foreground'>Featured</span>
          )}
        </div>
        <h1 class='font-serif text-3xl font-light leading-tight tracking-tight sm:text-4xl'>{entry.data.title}</h1>
        <p class='text-muted-foreground text-xl leading-relaxed'>{entry.data.description}</p>

        {
          entry.data.url && (
            <Button asChild size='lg'>
              <a href={entry.data.url} target='_blank' rel='noopener noreferrer'>
                Visit Resource
                <ArrowUpRightIcon className='size-4' />
              </a>
            </Button>
          )
        }
      </div>

      <Separator />

      {/* Tags */}
      {
        entry.data.tags.length > 0 && (
          <div class='flex flex-wrap items-center gap-2'>
            <span class='text-muted-foreground text-sm font-medium'>Tags:</span>
            {entry.data.tags.map(tag => (
              <Badge variant='outline' className='text-sm font-normal'>
                {tag}
              </Badge>
            ))}
          </div>
        )
      }

      {/* Body content (markdown notes) */}
      <article class='prose prose-neutral dark:prose-invert max-w-none'>
        <Content />
      </article>

      {/* Back link */}
      <div class='border-t pt-8'>
        <Button variant='outline' asChild className='rounded-xl'>
          <a href='/directory'>
            <ChevronLeftIcon className='size-4' />
            Back to Directory
          </a>
        </Button>
      </div>
    </div>
  </section>

  {/* Related entries */}
  {
    relatedItems.length > 0 && (
      <section class='bg-muted py-12 sm:py-16'>
        <div class='mx-auto max-w-7xl space-y-8 px-4 sm:px-6 lg:px-8'>
          <div class='space-y-2'>
            <Badge variant='outline'>More in {entry.data.category}</Badge>
            <h2 class='text-2xl font-semibold'>Related Resources</h2>
          </div>
          <div class='grid gap-5 sm:grid-cols-2 lg:grid-cols-3'>
            {relatedItems.map(item => (
              <a href={`/directory/${item.id}`} class='group'>
                <div class='bg-card rounded-lg border p-5 transition-shadow hover:shadow-md'>
                  <h3 class='font-semibold transition-colors group-hover:text-primary'>{item.data.title}</h3>
                  <p class='text-muted-foreground mt-1.5 text-sm'>{item.data.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</Layout>
