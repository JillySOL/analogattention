---
import Layout from '@/layouts/Layout.astro'

const pageTitle = 'About — analogattention'
const pageDescription =
  'About the author behind analogattention, an independent journal on digital minimalism and intentional technology.'
---

<Layout title={pageTitle} description={pageDescription}>
  <section class='py-20 sm:py-24 lg:py-28'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <h1 class='font-serif text-4xl font-light leading-[1.06] tracking-tight sm:text-5xl lg:text-6xl'>About</h1>
      <div class='mt-8 max-w-2xl space-y-5'>
        <p class='text-lg leading-relaxed text-muted-foreground'>
          analogattention is an independent publication exploring the relationship between attention, technology, and
          intentional living. Clarity of mind comes from deliberate choices about where we direct our focus.
        </p>
        <p class='leading-relaxed text-muted-foreground'>
          The journal explores digital minimalism, deep work, analog practices, and the philosophy of living well in a
          hyperconnected world.
        </p>
      </div>

      <div class='mt-14 max-w-2xl space-y-5 border-t border-border pt-10'>
        <h2 class='font-serif text-2xl font-semibold tracking-tight sm:text-3xl'>About the author</h2>
        <p class='leading-relaxed text-muted-foreground'>
          This project is written as an independent, ad-free publication by a practitioner of intentional technology.
          The writing is personal, practical, and built from lived experiments with attention.
        </p>
        <p class='leading-relaxed text-muted-foreground'>
          If you want to collaborate, share an idea, or ask a question, visit the contact page. Conversations with
          readers shape what gets written next.
        </p>
      </div>
    </div>
  </section>
</Layout>
