---
import Layout from '@/layouts/Layout.astro'

import ContactUs from '@/components/blocks/contact-us/contact-us'

// Page-specific SEO configuration
const pageTitle = 'Contact — analogattention'
const pageDescription =
  'Contact analogattention for partnerships, editorial opportunities, and conversations around digital minimalism and intentional technology.'
const pageKeywords =
  'contact analogattention, digital minimalism consulting, editorial partnerships, intentional technology'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact analogattention',
  description: pageDescription,
  about: {
    '@type': 'Organization',
    name: 'analogattention',
    url: 'https://analogattention.com/'
  }
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <ContactUs />
</Layout>
