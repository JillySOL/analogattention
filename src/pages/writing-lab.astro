---
import Layout from '@/layouts/Layout.astro'

const pageTitle = 'Writing Lab — analogattention'
const pageDescription =
  'Extend your essays in your own voice. Paste your reference writing, describe what to continue, and generate a style-matched draft.'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageTitle,
  description: pageDescription,
  url: 'https://analogattention.com/writing-lab'
}
---

<Layout title={pageTitle} description={pageDescription} schema={schema}>
  <section class='py-20 sm:py-24'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <h1 class='font-serif text-4xl font-light leading-[1.06] tracking-tight sm:text-5xl'>Writing Lab</h1>
      <p class='mt-5 max-w-2xl text-lg leading-relaxed text-muted-foreground'>
        Build drafts in your own style. Paste reference writing, describe what you want to continue, and generate a
        first-pass style prompt that sounds like you. You can run it directly in your preferred AI editor.
      </p>

      <div class='mt-10 space-y-6'>
        <div class='space-y-2'>
          <label for='referenceText' class='text-sm font-medium'>Reference writing</label>
          <textarea
            id='referenceText'
            class='min-h-52 w-full rounded-lg border bg-background px-3 py-2 text-sm outline-none focus-visible:ring-2 focus-visible:ring-ring'
            placeholder='Paste 2-5 strong samples of your writing style...'
          ></textarea>
        </div>

        <div class='space-y-2'>
          <label for='prompt' class='text-sm font-medium'>What should the assistant write?</label>
          <textarea
            id='prompt'
            class='min-h-28 w-full rounded-lg border bg-background px-3 py-2 text-sm outline-none focus-visible:ring-2 focus-visible:ring-ring'
            placeholder='Example: Continue this essay with 3 practical methods for reducing digital noise without becoming disconnected.'
          ></textarea>
        </div>

        <div class='space-y-2'>
          <label for='tone' class='text-sm font-medium'>Tone guidance (optional)</label>
          <input
            id='tone'
            class='h-10 w-full rounded-lg border bg-background px-3 text-sm outline-none focus-visible:ring-2 focus-visible:ring-ring'
            value='calm, reflective, clear, practical'
          />
        </div>

        <div class='flex items-center gap-3'>
          <button
            id='generateBtn'
            class='rounded-md bg-foreground px-4 py-2 text-sm font-medium text-background transition-opacity hover:opacity-85'
          >
            Generate Draft
          </button>
          <span id='status' class='text-sm text-muted-foreground'></span>
        </div>

        <div class='space-y-2'>
          <label for='output' class='text-sm font-medium'>Generated draft</label>
          <textarea
            id='output'
            class='min-h-56 w-full rounded-lg border bg-background px-3 py-2 text-sm outline-none focus-visible:ring-2 focus-visible:ring-ring'
            placeholder='Your style-matched prompt or generated draft will appear here...'
          ></textarea>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const generateBtn = document.getElementById('generateBtn')
  const status = document.getElementById('status')
  const referenceText = document.getElementById('referenceText')
  const prompt = document.getElementById('prompt')
  const tone = document.getElementById('tone')
  const output = document.getElementById('output')

  generateBtn?.addEventListener('click', async () => {
    const ref = referenceText && 'value' in referenceText ? referenceText.value.trim() : ''
    const task = prompt && 'value' in prompt ? prompt.value.trim() : ''
    const toneValue = tone && 'value' in tone ? tone.value.trim() : ''

    if (!ref || !task) {
      if (status) status.textContent = 'Please add reference writing and a prompt.'
      return
    }

    if (status) status.textContent = 'Preparing style prompt...'

    const stylePrompt = [
      'You are my personal writing assistant. Match my voice from the reference text below.',
      'Keep sentence rhythm, level of clarity, and structure aligned with the reference.',
      `Preferred tone: ${toneValue || 'calm, reflective, clear, practical'}.`,
      '',
      'Reference text:',
      ref,
      '',
      'Task to write:',
      task,
      '',
      'Output requirements:',
      '- Return only markdown body content',
      '- No generic AI disclaimers',
      '- Keep the language precise and human'
    ].join('\n')

    try {
      if (output && 'value' in output) {
        output.value = stylePrompt
      }

      const externalEndpoint = localStorage.getItem('writingLabEndpoint')
      if (externalEndpoint) {
        const res = await fetch(externalEndpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ referenceText: ref, prompt: task, tone: toneValue, stylePrompt })
        })

        if (res.ok) {
          const data = await res.json()
          if (output && 'value' in output && data.text) {
            output.value = data.text
          }
          if (status) status.textContent = 'Draft generated via configured endpoint.'
          return
        }
      }

      if (status) status.textContent = 'Style prompt generated. Configure writingLabEndpoint in localStorage to auto-generate drafts.'
    } catch {
      if (status) status.textContent = 'Style prompt generated. External endpoint request failed.'
    }
  })
</script>
