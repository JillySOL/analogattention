---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'

import CTA from '@/components/blocks/cta-section/cta-section'
import { calculateReadTime } from '@/utils/blog'

const allPosts = await getCollection('blog')
const sortedPosts = [...allPosts].sort((a, b) => b.data.id - a.data.id)
const recentPosts = sortedPosts.slice(0, 6)

const pageTitle = 'analogattention — Essays on Digital Minimalism'
const pageDescription =
  'analogattention is a digital garden for thinking clearly. Essays and resources on digital minimalism, intentional technology use, and reclaiming attention in a hyperconnected world.'
const pageKeywords =
  'digital minimalism, intentional technology, analog living, attention economy, deep work, slow living'
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'analogattention',
  description: pageDescription
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>

  {/* Hero — force dark regardless of theme */}
  <section class='dark bg-background text-foreground py-28 sm:py-36 lg:py-48'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <h1 class='font-serif text-5xl font-light leading-[1.06] tracking-tight sm:text-6xl lg:text-7xl'>
        A digital garden<br class='hidden sm:block' />
        for thinking clearly.
      </h1>
      <p class='mt-7 max-w-lg text-lg leading-relaxed text-muted-foreground'>
        analogattention is a digital garden for digital minimalism, intentional technology, and reclaiming attention.
      </p>
      <div class='mt-8 flex items-center gap-6'>
        <a href='/blog' class='text-sm font-medium underline underline-offset-4 hover:opacity-70 transition-opacity'>
          Read the journal →
        </a>
        <a href='/directory' class='text-sm text-muted-foreground hover:text-foreground transition-colors'>
          Browse resources
        </a>
      </div>
    </div>
  </section>

  {/* Recent Essays — flat list */}
  <section id='journal' class='py-20 sm:py-28'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <div class='mb-10 flex items-baseline justify-between gap-4'>
        <h2 class='font-serif text-2xl font-semibold tracking-tight'>Recent Essays</h2>
        <a
          href='/blog'
          class='text-sm text-muted-foreground hover:text-foreground underline underline-offset-4 transition-colors'
        >
          All essays
        </a>
      </div>

      <div class='divide-y divide-border'>
        {
          recentPosts.map(post => {
            const readTime = post.data.readTime || calculateReadTime(post.body)
            return (
              <a
                href={`/blog/${post.id}`}
                class='group flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:gap-10'
              >
                <span class='w-28 shrink-0 text-[0.68rem] font-semibold uppercase tracking-widest text-muted-foreground'>
                  {post.data.category}
                </span>
                <div class='flex-1 space-y-1.5'>
                  <p class='font-semibold leading-snug tracking-tight group-hover:underline group-hover:underline-offset-2'>
                    {post.data.title}
                  </p>
                  <p class='line-clamp-2 text-sm leading-relaxed text-muted-foreground'>
                    {post.data.description}
                  </p>
                </div>
                <div class='flex shrink-0 items-center gap-2 text-xs text-muted-foreground sm:flex-col sm:items-end sm:gap-1'>
                  <span>{post.data.pubDate}</span>
                  <span class='sm:hidden'>&middot;</span>
                  <span>{readTime} min</span>
                </div>
              </a>
            )
          })
        }
      </div>
    </div>
  </section>

  {/* About strip */}
  <section id='about' class='border-y border-border bg-muted py-20 sm:py-28'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <div class='max-w-2xl space-y-5'>
        <h2 class='font-serif text-3xl font-semibold tracking-tight sm:text-4xl'>About analogattention</h2>
        <p class='text-lg leading-relaxed text-muted-foreground'>
          analogattention is an independent publication exploring the relationship between attention, technology, and
          intentional living. We believe clarity of mind comes from deliberate choices about where we direct our
          focus.
        </p>
        <p class='leading-relaxed text-muted-foreground'>
          The journal covers digital minimalism, deep work, analog practices, and the philosophy of living well in a
          hyperconnected world. Independent, ad-free, and written to last.
        </p>
      </div>
    </div>
  </section>

  <CTA />
</Layout>
