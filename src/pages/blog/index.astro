---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { calculateReadTime } from '@/utils/blog'

const allPosts = await getCollection('blog')
const sortedPosts = [...allPosts].sort((a, b) => b.data.id - a.data.id)

// Unique categories for filter pills
const allCategories = [...new Set(sortedPosts.map(p => p.data.category))]

const pageTitle = 'Journal — analogattention'
const pageDescription =
  'All essays on digital minimalism, intentional technology use, and reclaiming attention in a hyperconnected world.'
---

<Layout title={pageTitle} description={pageDescription}>
  {/* Page Header */}
  <section class='py-20 sm:py-24 lg:py-28'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <h1 class='font-serif text-4xl font-light leading-[1.06] tracking-tight sm:text-5xl lg:text-6xl'>Archive</h1>
      <p class='mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground'>
        All essays, sorted by newest first. On attention, technology, and the art of living deliberately.
      </p>

      {/* Category filter pills */}
      <div class='mt-8 flex flex-wrap gap-2' id='filter-row'>
        <button
          class='filter-pill rounded-full border border-border bg-foreground px-3.5 py-1.5 text-xs font-semibold text-background transition-colors'
          data-category='all'
        >
          All
        </button>
        {
          allCategories.map(cat => (
            <button
              class='filter-pill rounded-full border border-border px-3.5 py-1.5 text-xs font-semibold text-muted-foreground transition-colors hover:border-foreground hover:text-foreground'
              data-category={cat}
            >
              {cat}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  {/* Post List */}
  <section class='pb-24'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <div class='divide-y divide-border' id='post-list'>
        {
          sortedPosts.map(post => {
            const readTime = post.data.readTime || calculateReadTime(post.body)
            return (
              <a
                href={`/blog/${post.id}`}
                class='post-item group flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:gap-10'
                data-category={post.data.category}
              >
                <span class='w-32 shrink-0 text-[0.68rem] font-semibold uppercase tracking-widest text-muted-foreground'>
                  {post.data.category}
                </span>
                <div class='flex-1 space-y-1.5'>
                  <p class='font-semibold leading-snug tracking-tight group-hover:underline group-hover:underline-offset-2'>
                    {post.data.title}
                  </p>
                  <p class='line-clamp-2 text-sm leading-relaxed text-muted-foreground'>
                    {post.data.description}
                  </p>
                </div>
                <div class='flex shrink-0 items-center gap-2 text-xs text-muted-foreground sm:flex-col sm:items-end sm:gap-1'>
                  <span>{post.data.pubDate}</span>
                  <span class='sm:hidden'>&middot;</span>
                  <span>{readTime} min read</span>
                </div>
              </a>
            )
          })
        }
      </div>
    </div>
  </section>
</Layout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill')
  const items = document.querySelectorAll<HTMLElement>('.post-item')

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const cat = pill.dataset.category ?? 'all'

      // Update active pill styles
      pills.forEach(p => {
        p.classList.remove('bg-foreground', 'text-background', 'border-foreground')
        p.classList.add('text-muted-foreground')
      })
      pill.classList.add('bg-foreground', 'text-background', 'border-foreground')
      pill.classList.remove('text-muted-foreground')

      // Show/hide posts
      items.forEach(item => {
        if (cat === 'all' || item.dataset.category === cat) {
          item.style.display = ''
        } else {
          item.style.display = 'none'
        }
      })
    })
  })
</script>
