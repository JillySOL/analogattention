---
import Layout from '@/layouts/Layout.astro'
import { getCollection } from 'astro:content'
import { calculateReadTime } from '@/utils/blog'

const allPosts = await getCollection('blog')
const sortedPosts = [...allPosts].sort((a, b) => b.data.id - a.data.id)
const collectionTypes = ['Getting Started', 'Common Challenges', 'Philosophical', 'Talking Points']

const pageTitle = 'Journal — analogattention'
const pageDescription =
  'All journals on digital minimalism, intentional technology use, and reclaiming attention in a hyperconnected world.'
---

<Layout title={pageTitle} description={pageDescription}>
  {/* Page Header */}
  <section class='py-20 sm:py-24 lg:py-28'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <h1 class='font-serif text-4xl font-light leading-[1.06] tracking-tight sm:text-5xl lg:text-6xl'>Journals</h1>
      <p class='mt-5 max-w-xl text-lg leading-relaxed text-muted-foreground'>
        Filter by collection and switch chronological order. On attention, technology, and the art of living
        deliberately.
      </p>

      <div class='mt-8 flex flex-wrap items-end gap-4'>
        <label class='flex flex-col gap-2'>
          <span class='text-xs font-semibold uppercase tracking-widest text-muted-foreground'>Collection</span>
          <select
            id='collection-filter'
            class='h-11 rounded-xl border border-border bg-background px-3 text-sm text-foreground outline-none transition-colors focus:border-foreground'
          >
            <option value='all'>All collections</option>
            {collectionTypes.map(type => <option value={type}>{type}</option>)}
          </select>
        </label>

        <button
          id='order-toggle'
          type='button'
          class='inline-flex items-center gap-1.5 text-xs text-muted-foreground transition-colors hover:text-foreground sm:justify-self-end'
          aria-label='Toggle chronological order'
          title='Newest first'
        >
          <span id='order-icon' aria-hidden='true'>↓</span>
          <span id='order-label'>Newest first</span>
        </button>
      </div>
    </div>
  </section>

  {/* Post List */}
  <section class='pb-24'>
    <div class='mx-auto max-w-4xl px-4 sm:px-6 lg:px-8'>
      <div class='divide-y divide-border' id='post-list'>
        {
          sortedPosts.map(post => {
            const readTime = post.data.readTime || calculateReadTime(post.body)
            return (
              <a
                href={`/blog/${post.id}`}
                class='post-item group flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:gap-10'
                data-collection={post.data.collection}
                data-sort-id={post.data.id}
              >
                <span class='w-32 shrink-0 text-[0.68rem] font-semibold uppercase tracking-widest text-muted-foreground'>
                  {post.data.collection}
                </span>
                <div class='flex-1 space-y-1.5'>
                  <p class='font-semibold leading-snug tracking-tight group-hover:underline group-hover:underline-offset-2'>
                    {post.data.title}
                  </p>
                  <p class='line-clamp-2 text-sm leading-relaxed text-muted-foreground'>
                    {post.data.description}
                  </p>
                </div>
                <div class='flex shrink-0 items-center gap-2 text-xs text-muted-foreground sm:flex-col sm:items-end sm:gap-1'>
                  <span>{post.data.pubDate}</span>
                  <span class='sm:hidden'>&middot;</span>
                  <span>{readTime} min read</span>
                </div>
              </a>
            )
          })
        }
      </div>
    </div>
  </section>
</Layout>

<script>
  const filterSelect = document.querySelector<HTMLSelectElement>('#collection-filter')
  const orderToggle = document.querySelector<HTMLButtonElement>('#order-toggle')
  const orderIcon = document.querySelector<HTMLSpanElement>('#order-icon')
  const orderLabel = document.querySelector<HTMLSpanElement>('#order-label')
  const postList = document.querySelector<HTMLElement>('#post-list')
  const postItems = Array.from(document.querySelectorAll<HTMLElement>('.post-item'))
  let oldestFirst = false

  const renderOrderState = () => {
    if (!orderIcon) return
    orderIcon.textContent = oldestFirst ? '↑' : '↓'
    if (orderLabel) orderLabel.textContent = oldestFirst ? 'Oldest first' : 'Newest first'
  }

  const applyFilters = () => {
    if (!filterSelect || !postList) return

    const selectedCollection = filterSelect.value || 'all'

    const visibleItems = postItems
      .filter(item => selectedCollection === 'all' || item.dataset.collection === selectedCollection)
      .sort((a, b) => {
        const idA = Number(a.dataset.sortId || '0')
        const idB = Number(b.dataset.sortId || '0')
        return oldestFirst ? idA - idB : idB - idA
      })

    postItems.forEach(item => {
      item.style.display = 'none'
    })

    visibleItems.forEach(item => {
      item.style.display = ''
      postList.appendChild(item)
    })

    const params = new URLSearchParams(window.location.search)
    if (selectedCollection !== 'all') {
      params.set('collection', selectedCollection)
    } else {
      params.delete('collection')
    }

    params.set('order', oldestFirst ? 'asc' : 'desc')
    const nextQuery = params.toString()
    const nextUrl = nextQuery ? `${window.location.pathname}?${nextQuery}` : window.location.pathname
    window.history.replaceState({}, '', nextUrl)
  }

  const hydrateFromUrl = () => {
    if (!filterSelect) return
    const params = new URLSearchParams(window.location.search)
    const requestedCollection = params.get('collection')
    const requestedOrder = params.get('order')

    if (requestedCollection && Array.from(filterSelect.options).some(option => option.value === requestedCollection)) {
      filterSelect.value = requestedCollection
    }

    oldestFirst = requestedOrder === 'asc'
    renderOrderState()
  }

  hydrateFromUrl()
  applyFilters()

  filterSelect?.addEventListener('change', applyFilters)
  orderToggle?.addEventListener('click', () => {
    oldestFirst = !oldestFirst
    renderOrderState()
    applyFilters()
  })
</script>
